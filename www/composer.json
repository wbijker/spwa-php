{
    "name": "spwa/test",
    "type": "library",
    "version": "1.0.0",
    "autoload": {
        "psr-4": {
            "App\\": "App/"
        }
    },
    "repositories": [
        {
            "packagist": false
        },
        {
            "type": "path",
            "url": "../spwa/"
        },
        {
            "type": "path",
            "url": "../codequery/"
        },
        {
            "type": "path",
            "url": "../heroicons/"
        },
        {
            "type": "path",
            "url": "../samples/News/"
        },
        {
            "type": "path",
            "url": "../samples/SiteApp/"
        }
    ],
    "require": {
        "spwa/spwa": "*",
        "itecho/codequery": "*",
        "itecho/heroicons": "*",
        "samples/news": "*",
        "samples/site-app": "*",
        "ext-json": "*",
        "ext-zlib": "*"
    },
    "config": {
        "disable-tls": true
    }
}
