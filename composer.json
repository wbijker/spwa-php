{
    "name": "brickphp/brickphp",
    "type": "library",
    "description": "Server-powered web applications, built brick by brick — entirely in PHP. No JavaScript framework, no build pipeline, no Node.",
    "keywords": ["framework", "server-driven", "components", "ui", "no-js", "hmr", "ssr"],
    "homepage": "https://github.com/wbijker/brickphp",
    "license": "MIT",
    "authors": [
        {
            "name": "Willem Bijker",
            "email": "willem@itecho.co.za"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "BrickPHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BrickPHP\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
